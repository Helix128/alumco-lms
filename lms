#!/bin/bash
set -euo pipefail

SAIL="./vendor/bin/sail"
DOCKER_PROD=(sudo docker compose -f compose.prod.yaml)

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then
    shift
fi

prod_artisan() {
    "${DOCKER_PROD[@]}" exec app php artisan "$@"
}

prod_preflight() {
    local missing=0

    for file in .env compose.prod.yaml docker/8.4-trixie/Dockerfile docker/8.4-trixie/entrypoint.sh; do
        if [ ! -f "$file" ]; then
            echo "Falta $file"
            missing=1
        fi
    done

    for binary in curl docker git sudo; do
        if ! command -v "$binary" >/dev/null 2>&1; then
            echo "$binary no esta disponible en PATH."
            missing=1
        fi
    done

    if [ "$missing" -ne 0 ]; then
        exit 1
    fi

    "${DOCKER_PROD[@]}" config >/dev/null
}

prod_build() {
    echo "Compilando imagenes de produccion..."
    "${DOCKER_PROD[@]}" build "$@" app web
}

prod_up() {
    echo "Iniciando contenedores de produccion..."
    "${DOCKER_PROD[@]}" up -d
}

prod_down() {
    echo "Apagando contenedores de produccion..."
    "${DOCKER_PROD[@]}" down
}

prod_health() {
    local port_output=""
    local host_port=""
    local attempt
    local max_attempts=5
    local sleep_time=0.5

    echo "Obteniendo puerto del servicio web..."
    for attempt in $(seq 1 10); do
        # Timeout de 5s para el comando docker port por si docker daemon no responde
        port_output=$(timeout 5 "${DOCKER_PROD[@]}" port web 80 2>/dev/null) || port_output=""
        host_port="${port_output##*:}"
        if [ -n "$host_port" ]; then
            break
        fi
        printf "."
        sleep 1
    done
    echo ""

    if [ -z "$host_port" ]; then
        echo "Error: No se pudo resolver el puerto publicado del servicio web."
        exit 1
    fi

    local url="http://127.0.0.1:${host_port}/up"
    echo "Verificando salud en $url..."
    
    for attempt in $(seq 1 "$max_attempts"); do
        printf "Intento %02d/%d: " "$attempt" "$max_attempts"
        if curl --fail --silent --connect-timeout 5 --max-time 5 "$url" >/dev/null; then
            echo "EXITO"
            return 0
        fi
        echo "esperando..."
        sleep "$sleep_time"
    done

    echo "ERROR: El health check falló después de $max_attempts intentos."
    echo "Detalle del error final:"
    curl --fail --show-error --connect-timeout 5 --max-time 5 "$url" || true
    exit 1
}

prod_deploy() {
    prod_preflight

    echo ">>> Iniciando despliegue de producción..."

    echo ">>> [1/7] Actualizando código fuente..."
    git pull origin main

    echo ">>> [2/7] Compilando imágenes..."
    prod_build "$@"

    echo ">>> [3/7] Modo mantenimiento: ON"
    prod_artisan down --render="errors::503" || true

    echo ">>> [4/7] Reiniciando contenedores..."
    prod_up

    echo ">>> [5/7] Reiniciando colas..."
    prod_artisan queue:restart || true

    echo ">>> [6/7] Modo mantenimiento: OFF"
    prod_artisan up || true

    echo ">>> [7/7] Verificando salud del sistema..."
    prod_health

    echo ">>> DESPLIEGUE FINALIZADO CORRECTAMENTE."
}

prod_clean() {
    echo "Limpiando imagenes huerfanas..."
    sudo docker image prune -f
}

show_help() {
    printf "Uso: ./lms [comando] [argumentos]\n\n"
    printf "%-15s %s\n" "DEV:" ""
    printf "  %-15s %s\n" "dev-start" "inicia sail"
    printf "  %-15s %s\n" "dev-rebuild" "reconstruye sail sin cache"
    printf "  %-15s %s\n" "dev-stop" "apaga sail"
    printf "\n%-15s %s\n" "PROD:" ""
    printf "  %-15s %s\n" "prod-deploy" "pull, build, up, queue restart y health check"
    printf "  %-15s %s\n" "prod-build" "compila imagenes app/web; acepta --no-cache"
    printf "  %-15s %s\n" "prod-up" "levanta contenedores"
    printf "  %-15s %s\n" "prod-down" "baja contenedores"
    printf "  %-15s %s\n" "prod-health" "valida /up"
    printf "  %-15s %s\n" "prod-artisan" "php artisan (ej: migrate:status)"
    printf "  %-15s %s\n" "prod-exec" "comando libre en un servicio"
    printf "  %-15s %s\n" "prod-clean" "libera imagenes huerfanas"
    printf "\nEjemplos:\n"
    printf "  ./lms prod-artisan migrate:status\n"
    printf "  ./lms prod-artisan db:seed --force\n"
    printf "  ./lms prod-artisan storage:link\n"
    printf "  ./lms prod-artisan route:list --path=livewire\n"
}

case "$cmd" in
    dev-start)
        echo "Iniciando server dev..."
        $SAIL up -d
        ;;
    dev-rebuild)
        echo "Reconstruyendo imagenes de dev sin cache..."
        $SAIL build --no-cache
        ;;
    dev-stop)
        echo "Apagando server dev..."
        $SAIL stop
        ;;
    prod-deploy)
        prod_deploy "$@"
        ;;
    prod-build)
        prod_preflight
        prod_build "$@"
        ;;
    prod-up | prod-start)
        prod_preflight
        prod_up
        ;;
    prod-down | prod-stop)
        prod_preflight
        prod_down
        ;;
    prod-health)
        prod_preflight
        prod_health
        ;;
    prod-clean)
        prod_clean
        ;;
    prod-artisan)
        prod_preflight
        echo "Ejecutando artisan en produccion..."
        prod_artisan "$@"
        ;;
    prod-exec)
        prod_preflight
        service="${1:-}"
        if [ -z "$service" ]; then
            echo "Debes indicar el servicio."
            exit 1
        fi
        shift
        echo "Ejecutando comando en $service..."
        "${DOCKER_PROD[@]}" exec "$service" "$@"
        ;;
    help | --help | -h)
        show_help
        ;;
    *)
        show_help
        exit 1
        ;;
esac
