#!/bin/bash

# Configuración
SAIL="./vendor/bin/sail"
DOCKER_PROD="docker compose -f compose.prod.yaml"

cmd=$1
shift

case $cmd in
    dev-start)
        echo "Iniciando server dev..."
        $SAIL up -d
        ;;
    dev-rebuild)
        echo "Reconstruyendo imágenes de dev (sin cache)..."
        $SAIL build --no-cache
        ;;
    dev-stop)
        echo "Apagando server dev..."
        $SAIL stop
        ;;
    prod-build)
        echo "Compilando imagen prod..."
        $DOCKER_PROD build
        ;;
    prod-start)
        echo "Iniciando server prod..."
        $DOCKER_PROD up -d
        ;;
    prod-stop)
        echo "Apagando server prod..."
        $DOCKER_PROD down
        ;;
    prod-clean)
        echo "Limpiando imagenes huerfanas..."
        docker image prune -f
        ;;
    prod-artisan)
        echo "Ejecutando artisan en prod..."
        $DOCKER_PROD exec app php artisan "$@"
        ;;
    prod-exec)
        servicio=$1
        shift
        echo "Ejecutando comando en $servicio..."
        $DOCKER_PROD exec "$servicio" "$@"
        ;;
    *)
        printf "Uso: ./lms [comando] [argumentos]\n\n"
        printf "%-15s %s\n" "DEV:" ""
        printf "  %-13s %s\n" "dev-start" "inicia sail"
        printf "  %-13s %s\n" "dev-rebuild" "reconstruye sail sin cache"
        printf "  %-13s %s\n" "dev-stop" "apaga sail"
        printf "\n%-15s %s\n" "PROD:" ""
        printf "  %-13s %s\n" "prod-build" "compila imagen"
        printf "  %-13s %s\n" "prod-start" "levanta contenedores"
        printf "  %-13s %s\n" "prod-stop" "baja contenedores"
        printf "  %-13s %s\n" "prod-clean" "libera espacio"
        printf "  %-13s %s\n" "prod-artisan" "php artisan (ej: migrate)"
        printf "  %-13s %s\n" "prod-exec" "comando libre (ej: mysql bash)"
        ;;
esac